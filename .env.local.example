# ---------------------------------------------------------------------------
# School of Athens — environment variables
# Copy this file to .env.local and fill in your own values.
# ---------------------------------------------------------------------------

# --- Firebase client (browser) config -------------------------------------
# Found in Firebase console > Project settings > Your apps > SDK setup.
# NEXT_PUBLIC_* vars are exposed to the browser (this is expected for Firebase).
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:abc123

# --- Firebase Admin (server) credentials ----------------------------------
# Service account JSON, base64-encoded. Generate with:
#   base64 -i serviceAccountKey.json | tr -d '\n'
# (Firebase console > Project settings > Service accounts > Generate new key)
FIREBASE_SERVICE_ACCOUNT_B64=

# --- Anthropic / Claude ----------------------------------------------------
ANTHROPIC_API_KEY=
# Model used to pick the next question + write coaching feedback.
CLAUDE_MODEL=claude-sonnet-4-6

# --- Tutor platform ---------------------------------------------------------
# Shared secret that gates tutor account creation at /tutor/signup.
TUTOR_ACCESS_CODE=change-me

# --- Local development with the Firebase emulator suite --------------------
# Set to "1" to point both client and admin SDKs at local emulators.
# When set, ANTHROPIC_API_KEY / FIREBASE_SERVICE_ACCOUNT_B64 are optional —
# the app falls back to a heuristic question picker.
NEXT_PUBLIC_USE_FIREBASE_EMULATOR=0
FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
